{
  "name": "briefops-monorepo",
  "private": true,
  "scripts": {
    "dev:backend": "./scripts/start-backend.sh",
    "dev:frontend": "./scripts/start-frontend.sh",
    "dev": "concurrently -k \"npm run dev:backend\" \"npm run dev:frontend\"",
    "test:backend": "npm --prefix backend run test",
    "test:frontend": "npm --prefix frontend run test",
    "test:e2e": "playwright test",
    "test": "./scripts/test-all.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "concurrently": "^9.1.2",
    "wait-on": "^8.0.3"
  }
}
